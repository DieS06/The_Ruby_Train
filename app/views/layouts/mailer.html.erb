<!DOCTYPE html>
<html>
  <head>
    <meta charset="UTF-8">
    <title><%= yield(:subject) || "The Ruby Train" %></title>
    <style>
      body {
        background-color: #f4f4f4;
        font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
        color: #333;
        margin: 0;
        padding: 0;
      }
      .container {
        max-width: 600px;
        margin: 2rem auto;
        background-color: #ffffff;
        border-radius: 8px;
        overflow: hidden;
        box-shadow: 0 0 12px rgba(0,0,0,0.05);
      }
      .header {
        background-color: #880E4F;
        color: white;
        text-align: center;
        padding: 1.5rem;
        font-size: 1.5rem;
      }
      .content {
        padding: 2rem;
      }
      .button {
        display: inline-block;
        padding: 0.75rem 1.5rem;
        margin: 1rem 0;
        background-color: #880E4F;
        color: white;
        text-decoration: none;
        border-radius: 6px;
        font-weight: bold;
      }
      .footer {
        text-align: center;
        font-size: 0.9rem;
        color: #999;
        padding: 1.5rem;
      }
    </style>
  </head>
  <body>
    <div class="container">
      <div class="header">
        The Ruby Train
      </div>
      <div class="content">
        <%= yield %>
      </div>
      <div class="footer">
        © <%= Time.current.year %> The Ruby Train. Todos los derechos reservados.
      </div>
    </div>
  </body>
</html>
