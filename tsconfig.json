{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "strict": true,
    "allowSyntheticDefaultImports": true,
    "isolatedModules": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["app/javascript/*"],
      "@assets/*": ["app/javascript/assets/*"],
      "@styles/*": ["app/javascript/styles/*"],
      "@types/*": ["app/javascript/types/*"],
      "@services/*": ["app/javascript/services/*"],
      "@stores/*": ["app/javascript/stores/*"],
      "@components/*": ["app/javascript/bundles/components/*"]
    },
    "types": ["node", "react"]
  },
  "include": ["app/javascript/**/*", "app/javascript/types"]
}
